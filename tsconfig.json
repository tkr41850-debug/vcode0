{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2024"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "allowJs": false,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@root/*": ["src/*.ts", "src/*/index.ts", "src/*"],
      "@app/*": ["src/app/*.ts", "src/app/*/index.ts", "src/app/*"],
      "@core/*": ["src/core/*.ts", "src/core/*/index.ts", "src/core/*"],
      "@orchestrator/*": [
        "src/orchestrator/*.ts",
        "src/orchestrator/*/index.ts",
        "src/orchestrator/*"
      ],
      "@agents": ["src/agents/index.ts"],
      "@agents/*": ["src/agents/*.ts", "src/agents/*/index.ts", "src/agents/*"],
      "@runtime/*": [
        "src/runtime/*.ts",
        "src/runtime/*/index.ts",
        "src/runtime/*"
      ],
      "@git": ["src/git/index.ts"],
      "@git/*": ["src/git/*.ts", "src/git/*/index.ts", "src/git/*"],
      "@persistence/*": [
        "src/persistence/*.ts",
        "src/persistence/*/index.ts",
        "src/persistence/*"
      ],
      "@tui/*": ["src/tui/*.ts", "src/tui/*/index.ts", "src/tui/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}

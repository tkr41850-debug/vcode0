{
  "name": "gvc0",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.6.3",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "fix": "npm run lint:fix",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "lint": "biome check --formatter-enabled=false --linter-enabled=true .",
    "lint:fix": "biome check --write .",
    "lint:ci": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"vitest.config.ts\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run check && npm run lint:ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}

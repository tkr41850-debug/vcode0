{
  "name": "gvc0",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "gvc0": "./dist/cli.js"
  },
  "packageManager": "npm@11.6.3",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "tui": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "fix": "npm run lint:fix",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "lint": "biome check --formatter-enabled=false --linter-enabled=true .",
    "lint:fix": "biome check --write .",
    "lint:ci": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"vitest.config.ts\" --max-warnings=0 --no-error-on-unmatched-pattern --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:unit:watch": "vitest test/unit",
    "test:integration": "vitest run test/integration",
    "test:integration:watch": "vitest test/integration",
    "typecheck": "tsc --noEmit",
    "verify": "npm run check && npm run lint:ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "json-schema-traverse": "^0.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-tui": "^0.66.1",
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^12.8.0",
    "simple-git": "^3.35.2"
  }
}
